# Server
PORT=8000
NODE_ENV=development

# Postgres (used by Drizzle + the app)
DATABASE_URL=postgres://postgres:password@localhost:5432/checkboxdb

# Redis / Valkey
# Note: current code connects to localhost:6379 directly (see redis-connection.js).
# This is kept here for future-proofing and for common tooling.
REDIS_URL=redis://localhost:6379

# Checkbox state
# Defaults: CHECKBOX_COUNT=2000, CHECKBOX_STATE_KEY=checkbox_state
CHECKBOX_COUNT=2000
CHECKBOX_STATE_KEY=checkbox_state

# JWT (RS256)
# Tokens are signed with the RSA keypair in cert/private-key.pem and cert/public-key.pub.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Unused (kept only because some local .env files include them)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
